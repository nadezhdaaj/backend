generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  username     String?
  avatarUrl    String?
  bio          String?

  points       Int      @default(0)
  
  quiz1Points  Int @default(0)
  title        String   @default("Новичок")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  artworks          Artwork[]
  exhibitFavorites  ExhibitFavorite[]
  exhibitViews      ExhibitView[]
  notes             Note[]
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  text      String
  category  String   @default("idea")
  exhibitId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Artwork {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title          String?
  description    String?
  kind           String   @default("painting")
  source         String   @default("paint-canvas")
  status         String   @default("DRAFT")
  schemaVersion  Int      @default(1)

  imageUrl       String
  thumbnailUrl   String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model QuizQuestion {
  id           String @id @default(uuid())
  question     String @unique
  fact         String
  correctIndex Int
  createdAt    DateTime @default(now())
  answers      QuizAnswer[]
}

model QuizAnswer {
  id          String   @id @default(uuid())
  text        String
  sortOrder   Int      @default(0)

  questionId  String
  question    QuizQuestion @relation(fields: [questionId], references: [id])
}

model ExhibitFavorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exhibitId String
  createdAt DateTime @default(now())

  @@unique([userId, exhibitId])
}

model ExhibitView {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exhibitId String
  createdAt DateTime @default(now())

  @@unique([userId, exhibitId])
}
